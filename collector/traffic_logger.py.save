import csv
import os

os.makedirs("data", exist_ok=True)

CSV_FILE = "data/network.csv"

if not os.path.exists(CSV_FILE):
    with open(CSV_FILE, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow([
            "packet_length",
            "protocol"
        ])

def packet_callback(packet):

    protocol = 0

    if packet.haslayer(IP):
        protocol = packet[IP].proto

    with open(CSV_FILE, "a", newline="") as f:
        writer = csv.writer(f)
        writer.writerow([
            len(packet),
            protocol
        ])

    print(
        f"Captured Length={len(packet)} "
        f"Protocol={protocol}"
    )

sniff(
    prn=packet_callback,
    store=False
)
